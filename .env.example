# Copy to .env and fill in. NEVER commit real keys.
OPENAI_API_KEY=                 # only needed to (re)generate synthetic dialogues
OPENAI_BASE_URL=https://api.openai.com/v1
NCBI_API_KEY=                   # optional, raises NCBI E-utilities rate limit to 10 req/s
NCBI_EMAIL=you@example.org      # required by NCBI Entrez usage policy
PHYSIONET_USER=                 # PhysioNet credentialed-access username (if used)
PHYSIONET_PASSWORD=
HF_TOKEN=                       # to pull the base model / push adapters
